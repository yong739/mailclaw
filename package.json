{
  "name": "mailclaw",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy --minify",
    "tail": "wrangler tail",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "wrangler d1 create mailclaw-d1",
    "db:tables": "wrangler d1 execute mailclaw-d1 --file ./sql/schema.sql --remote",
    "db:indexes": "wrangler d1 execute mailclaw-d1 --file ./sql/indexes.sql --remote",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write --unsafe ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write --unsafe ./src",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "hono": "^4.8.5",
    "html-to-text": "^9.0.5",
    "postal-mime": "^2.4.4",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.1.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.4"
  }
}
